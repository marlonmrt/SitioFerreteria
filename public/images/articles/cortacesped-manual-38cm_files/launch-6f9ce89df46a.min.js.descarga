.addEventListener(\"trackingEventStream\", function(event) {\n    try{\n      var eventName = event.detail.event;\n      var eventData = event.detail;\n      delete(eventData.event)\n      _satellite.track(eventName, eventData)\n      console.log(\"NEW TRACKING EVENT STREAM\", eventName, eventData);      \n    }catch(e){}\n  });\n\n\n  var mapAdobeProducts = function(products) {\n          var sProducts = [];\n          products.forEach(function(p) {\n              var sProduct = {\n                  category: p.main_category_clean ? p.main_category_clean : 'n/a',              \n                  sku: p.item_id ? p.item_id : 'n/a',\n                  quantity: p.quantity ? p.quantity : undefined,\n                  price: p.price ? (parseFloat(p.price) * parseInt(p.quantity)) : undefined,\n                  events: [],\n                  eVars: [{\n                      index: 3,\n                      value: p.item_name ? p.item_name : 'n/a',\n                  }, {\n                      index: 4,\n                      value: p.ean ? p.ean : 'n/a',\n                  }, {\n                      index: 5,\n                      value: p.parent_id ? p.parent_id : 'n/a',\n                  }, {\n                      index: 6,\n                      value: p.part_number ? p.part_number : 'n/a',\n                  }, {\n                      index: 7,\n                      value: p.marketplace ? p.marketplace : 'n/a',\n                  }, {\n                      index: 8,\n                      value: p.stock_web ? p.stock_web : 'n/a',\n                  }, {\n                      index: 9,\n                      value: p.brand ? p.brand : 'n/a',\n                  }],\n              }\n              sProduct.eVars = sProduct.eVars.map(function(e) {\n                  return 'eVar' + e.index + '=' + e.value\n              }).join('|');\n              if (sProduct.events.length === 0)\n                  sProduct.events = undefined;\n            \n              var